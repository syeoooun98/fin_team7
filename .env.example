# 자리지킴이 — 환경변수 예시. 실제 값은 .env(커밋 금지)에 채워 넣는다.

# Supabase 프로젝트 "fin_team7" (ref: dwyqdibgnecymaehkzik) 기준.
# 비밀번호는 Supabase 대시보드 > Project Settings > Database 에서 확인/재설정 (API로는 조회 불가).
# 런타임 쿼리(앱 서버) — Transaction pooler, 포트 6543
DATABASE_URL="postgresql://postgres.dwyqdibgnecymaehkzik:[YOUR-PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# 마이그레이션 전용(prisma migrate/db push) — 다이렉트 커넥션, 포트 5432
DIRECT_URL="postgresql://postgres.dwyqdibgnecymaehkzik:[YOUR-PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres"

# lib/auth.ts 세션 쿠키 서명용 비밀키. openssl rand -hex 32 등으로 생성.
SESSION_SECRET="change-me-to-a-long-random-string"

# app/api/cron/auto-expire가 확인하는 값. 설정 시 Authorization: Bearer <값> 요청만 허용.
CRON_SECRET="change-me"
