# 자리지킴이 — 환경변수 예시. 실제 값은 .env(커밋 금지)에 채워 넣는다.

# Supabase 프로젝트 "fin_team7" (ref: nigefilyramspwrmobyb, 2026-07-17 재생성) 기준.
# 비밀번호는 Supabase 대시보드 > Project Settings > Database 에서 확인/재설정 (API로는 조회 불가).
# 대괄호([ ])는 실제 값으로 통째로 치환 — 괄호 자체를 남기면 인증 실패한다.
# 샤드는 aws-0이 아니라 aws-1이 맞는 것으로 확인됨(2026-07-17 연결 테스트). 여전히 프로젝트마다
# 다르게 배정될 수 있으니, 값이 안 맞으면 대시보드 Connect 모달에서 정확한 호스트로 교체할 것.
# 런타임 쿼리(앱 서버) — Transaction 모드, 포트 6543
DATABASE_URL="postgresql://postgres.nigefilyramspwrmobyb:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# 마이그레이션 전용(prisma migrate/db push) — Session 모드, 포트 5432
DIRECT_URL="postgresql://postgres.nigefilyramspwrmobyb:[YOUR-PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres"

# lib/auth.ts 세션 쿠키 서명용 비밀키. openssl rand -hex 32 등으로 생성.
SESSION_SECRET="change-me-to-a-long-random-string"

# app/api/cron/auto-expire가 확인하는 값. 설정 시 Authorization: Bearer <값> 요청만 허용.
CRON_SECRET="change-me"
