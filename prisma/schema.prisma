// 자리지킴이 — Prisma 스키마
// DB.md (Draft v1.0) 2절 테이블 정의를 1:1로 옮긴 것. 컬럼 근거/설계 이유는 전부 DB.md 참고.
//
// 의도적 차이점 (DB.md 대비):
// 1) PK/FK 타입을 BIGSERIAL 대신 Int(SERIAL)로 사용한다.
//    - 이유: Prisma의 BigInt는 JS BigInt로 매핑되는데, Next.js API 라우트가 흔히 쓰는
//      JSON.stringify가 BigInt를 직렬화하지 못해 런타임 에러가 난다. 310석·학생 프로젝트
//      규모에서는 BIGSERIAL의 여유 범위가 필요 없으므로, JSON 직렬화 편의를 위해 Int로 낮췄다.
// 2) DB.md 2.5/2.6/2.7절의 "부분 유니크 인덱스"(WHERE절 있는 unique index)는
//    Prisma 스키마 DSL이 선언적으로 지원하지 않는다. 이 3개는 `prisma/partial_unique_indexes.sql`에
//    원본 SQL로 남겨두고, `prisma db push`/마이그레이션 이후 반드시 별도 적용해야 한다.
//    (F3 1인 1좌석, F13 좌석당 활성 신고 1건 같은 동시성 규칙이 여기 걸려있으므로 절대 생략 금지)
//
// 실제 DB: Supabase 프로젝트 "fin_team7" (ref: nigefilyramspwrmobyb, ap-northeast-2, 2026-07-17 재생성)에
// 이 스키마 그대로 적용 완료. 이전 프로젝트(ref: dwyqdibgnecymaehkzik)는 폐기되었다.
// Supabase 권장 방식대로 런타임 쿼리는 커넥션 풀러(6543), 마이그레이션은 다이렉트 커넥션(5432)을
// 쓰도록 url/directUrl을 분리했다 — .env.example 참고.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// 2.1 users — 이용자 계정 (근거: PRD F1, 14.1)
model User {
  id           Int      @id @default(autoincrement())
  studentId    String   @unique @map("student_id") @db.VarChar(20)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at")
  /// 본인이 획득한 배지 중 좌석 이용 중 남에게 보여줄 것으로 선택한 것 (없으면 NULL).
  /// 아이콘·제목만 노출되고 학번/이름은 절대 딸려 나가지 않는다 — F14 익명성 원칙 유지.
  equippedBadgeCode BadgeCode? @map("equipped_badge_code")

  seatSessions      SeatSession[]
  reportsFiled      Report[]           @relation("ReporterUser")
  notifications     Notification[]
  checkoutAlarms    CheckoutAlarm[]
  badges            UserBadge[]
  communityPosts    CommunityPost[]
  communityComments CommunityComment[]
  communityLikes    CommunityLike[]
  seatWatchRequests SeatWatchRequest[]

  @@map("users")
}

/// 2.2 zones — 구역 (근거: PRD 6.2)
model Zone {
  code        String  @id @db.VarChar(4)
  name        String  @db.VarChar(50)
  floor       Int     @db.SmallInt
  colorRef    String  @map("color_ref") @db.VarChar(20)
  description String?
  seatCount   Int     @map("seat_count") @db.SmallInt

  seats Seat[]

  @@map("zones")
}

/// 2.3 seats — 좌석 (근거: PRD 6.2/6.3/7.1, DB.md 14.3)
model Seat {
  id              Int        @id @default(autoincrement())
  seatCode        String     @unique @map("seat_code") @db.VarChar(20)
  zoneCode        String     @map("zone_code") @db.VarChar(4)
  /// GS 전용(01~10). 그 외 구역은 null. 예약 단위가 아니라 조회 편의용 속성(14.3 확정).
  roomNumber      Int?       @map("room_number") @db.SmallInt
  hasOutlet       Boolean    @default(false) @map("has_outlet")
  isWindow        Boolean    @default(false) @map("is_window")
  /// 비정규화 캐시. 진실의 원천은 SeatSession(활성 세션 유무) — DB.md 4절 참고.
  status          SeatStatus @default(AVAILABLE)
  /// 마지막 상태 변경 시각(일반 부기용 — 과거의 EMPTY→AVAILABLE buffer 계산 용도는 폐기됨)
  statusChangedAt DateTime   @default(now()) @map("status_changed_at")

  zone         Zone          @relation(fields: [zoneCode], references: [code])
  seatSessions SeatSession[]

  @@index([zoneCode])
  @@map("seats")
}

/// 2.4 away_categories — 자리비움 카테고리 코드 테이블 (근거: PRD F5, 10.1/10.2)
model AwayCategory {
  code         String  @id @db.VarChar(20)
  label        String  @db.VarChar(30)
  limitMinutes Int     @map("limit_minutes") @db.SmallInt
  sortOrder    Int     @map("sort_order") @db.SmallInt
  active       Boolean @default(true)

  awayPeriods AwayPeriod[]

  @@map("away_categories")
}

/// 2.5 seat_sessions — 체크인 세션 (근거: PRD F3/F4)
/// 부분 유니크 인덱스 2개(활성 세션은 좌석당 1개, 이용자당 1개)는
/// prisma/partial_unique_indexes.sql 로 별도 적용 — F3(1인 1좌석)를 DB 레벨에서 강제하는 핵심 제약.
model SeatSession {
  id             Int             @id @default(autoincrement())
  seatId         Int             @map("seat_id")
  userId         Int             @map("user_id")
  checkedInAt    DateTime        @default(now()) @map("checked_in_at")
  checkedOutAt   DateTime?       @map("checked_out_at")
  checkoutReason CheckoutReason? @map("checkout_reason")

  seat              Seat                @relation(fields: [seatId], references: [id])
  user              User                @relation(fields: [userId], references: [id])
  awayPeriods       AwayPeriod[]
  reports           Report[]
  notifications     Notification[]
  checkoutAlarms    CheckoutAlarm[]
  seatWatchRequests SeatWatchRequest[]

  @@index([seatId])
  @@index([userId])
  @@map("seat_sessions")
}

/// 2.6 away_periods — 자리비움 기록 (근거: PRD F5~F8, 10.3/10.4)
/// 부분 유니크 인덱스(세션당 활성 자리비움 1개)는 prisma/partial_unique_indexes.sql 참고.
model AwayPeriod {
  id            Int            @id @default(autoincrement())
  seatSessionId Int            @map("seat_session_id")
  categoryCode  String         @map("category_code") @db.VarChar(20)
  /// 신청 시점 값 스냅샷 (카테고리 제한시간이 나중에 바뀌어도 과거 기록은 불변)
  limitMinutes  Int            @map("limit_minutes") @db.SmallInt
  startedAt     DateTime       @default(now()) @map("started_at")
  endedAt       DateTime?      @map("ended_at")
  endReason     AwayEndReason? @map("end_reason")
  /// 20% 잔여 경고(10.3) 중복 발송 방지용
  warningSentAt DateTime?      @map("warning_sent_at")

  seatSession SeatSession  @relation(fields: [seatSessionId], references: [id])
  category    AwayCategory @relation(fields: [categoryCode], references: [code])

  @@index([seatSessionId])
  @@map("away_periods")
}

/// 2.7 reports — 무단 점유 신고 (근거: PRD F9~F14)
/// 부분 유니크 인덱스(세션당 활성 신고 1건, F13)는 prisma/partial_unique_indexes.sql 참고.
model Report {
  id               Int          @id @default(autoincrement())
  seatSessionId    Int          @map("seat_session_id")
  /// 민감 컬럼 — 어떤 조회 API/뷰에서도 일반 이용자에게 조인·노출 금지 (F14, DB.md 5절)
  reporterUserId   Int?         @map("reporter_user_id")
  reportedAt       DateTime     @default(now()) @map("reported_at")
  countdownEndsAt  DateTime     @map("countdown_ends_at")
  status           ReportStatus @default(ACTIVE)
  resolvedAt       DateTime?    @map("resolved_at")
  /// 20% 잔여 경고(10.3) 중복 발송 방지용
  warningSentAt    DateTime?    @map("warning_sent_at")
  /// 인증샷 미션(자리 복귀) 결과물 — Supabase Storage 오브젝트 경로(공개 URL이 아니다).
  /// 항상 signed URL로만 서빙한다 — private 버킷 + 서비스롤 키로만 접근하므로 URL 자체가
  /// 새어나가도 만료 전 잠깐을 제외하면 열람 불가(F14 익명성 원칙과 동일한 이유로 공개 경로 지양).
  photoPath        String?      @map("photo_path")

  seatSession   SeatSession     @relation(fields: [seatSessionId], references: [id])
  reporterUser  User?           @relation("ReporterUser", fields: [reporterUserId], references: [id])
  notifications Notification[]
  communityPost CommunityPost?

  @@index([seatSessionId])
  @@map("reports")
}

/// 2.8 notifications — 알림 (근거: PRD F16, 14.7)
model Notification {
  id            Int              @id @default(autoincrement())
  userId        Int              @map("user_id")
  type          NotificationType
  seatSessionId Int?             @map("seat_session_id")
  reportId      Int?             @map("report_id")
  /// 렌더링된 최종 문구. 상대방 식별정보 절대 포함 금지(F14) — 무엇을 넣을지는 서비스 레이어 책임.
  message       String
  createdAt     DateTime         @default(now()) @map("created_at")
  readAt        DateTime?        @map("read_at")

  user        User         @relation(fields: [userId], references: [id])
  seatSession SeatSession? @relation(fields: [seatSessionId], references: [id])
  report      Report?      @relation(fields: [reportId], references: [id])

  @@index([userId])
  @@map("notifications")
}

/// 2.9 checkout_alarms — "체크아웃 시 알림" 구독 (근거: PRD F22)
/// 이용 중(외출 포함)인 좌석에 대해 신청한 체크아웃 알림 구독. 신청 시점의 활성 세션
/// (seatSessionId)이 실제로 체크아웃되면 신청자에게 알림을 보내고 notifiedAt을 채운다.
/// 같은 세션에 같은 사용자가 중복 신청해도 @@unique로 1건만 유지된다(재신청은 idempotent).
model CheckoutAlarm {
  id            Int       @id @default(autoincrement())
  seatSessionId Int       @map("seat_session_id")
  userId        Int       @map("user_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  /// 알림 발송 시각 — null이면 아직 대상 세션이 체크아웃되지 않은 것
  notifiedAt    DateTime? @map("notified_at")

  seatSession SeatSession @relation(fields: [seatSessionId], references: [id])
  user        User        @relation(fields: [userId], references: [id])

  @@unique([seatSessionId, userId])
  @@index([seatSessionId])
  @@map("checkout_alarms")
}

/// 마이페이지 배지/칭호 시스템 — 조건을 충족하는 순간 lib/badges.ts가 upsert로 부여하고
/// 이후 조건을 더 이상 만족하지 못해도 유지되는 "업적"이다(게임의 도전과제와 동일한 개념).
model UserBadge {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  badgeCode   BadgeCode @map("badge_code")
  /// 월 단위 배지는 "YYYY-MM"(그 달에 한 번만 부여), 전체 기간 배지는 "ALL_TIME"
  periodLabel String   @map("period_label") @db.VarChar(20)
  awardedAt   DateTime @default(now()) @map("awarded_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, badgeCode, periodLabel])
  @@map("user_badges")
}

/// 커뮤니티 게시글 — 신고 복귀 인증샷을 본인이 공개 공유하기로 선택한 경우에만 생성된다.
/// reportId 1:1 — 신고 하나(=인증샷 하나)당 게시글은 최대 1개.
/// 작성자 신원(학번/이름)은 API 응답에 절대 포함하지 않는다 — 장착 배지(아이콘+제목)만 노출(F14 연장 적용).
model CommunityPost {
  id        Int      @id @default(autoincrement())
  reportId  Int      @unique @map("report_id")
  userId    Int      @map("user_id")
  /// Report.photoPath와 동일한 이유로 storage 오브젝트 경로만 저장 — signed URL은 조회 시 발급.
  photoPath String   @map("photo_path")
  createdAt DateTime @default(now()) @map("created_at")

  report   Report              @relation(fields: [reportId], references: [id])
  user     User                @relation(fields: [userId], references: [id])
  comments CommunityComment[]
  likes    CommunityLike[]

  @@index([userId])
  @@map("community_posts")
}

model CommunityComment {
  id        Int      @id @default(autoincrement())
  postId    Int      @map("post_id")
  userId    Int      @map("user_id")
  content   String   @db.VarChar(300)
  createdAt DateTime @default(now()) @map("created_at")

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id])

  @@index([postId])
  @@map("community_comments")
}

model CommunityLike {
  id        Int      @id @default(autoincrement())
  postId    Int      @map("post_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id])

  @@unique([postId, userId])
  @@index([postId])
  @@map("community_likes")
}

/// 좌석 알림 신청 — 팀원이 실제 DB에 먼저 만들어둔 기능(관심 좌석이 비면 알림)을 이 파일로
/// 역반영한 것. schema.prisma에 없던 상태로 라이브 DB에만 존재했어서 `db push`가 삭제 시도했다 —
/// 컬럼 구성은 실제 DB 그대로. RLS가 비활성화되어 있다는 보안 권고가 있었음(팀에 별도 공유 필요).
model SeatWatchRequest {
  id            Int       @id @default(autoincrement())
  seatSessionId Int       @map("seat_session_id")
  watcherUserId Int       @map("watcher_user_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  notifiedAt    DateTime? @map("notified_at")

  seatSession SeatSession @relation(fields: [seatSessionId], references: [id])
  watcherUser User        @relation(fields: [watcherUserId], references: [id])

  @@unique([seatSessionId, watcherUserId])
  @@map("seat_watch_requests")
}

/// 7.1 좌석 2대 상태(예약가능/이용중). "이용중"의 하위 표시(재실/외출)는 SeatStatus가 아니라
/// 활성 AwayPeriod 유무로 구분한다(EMPTY "방금 비었어요" 상태는 폐기 — 예약가능에 흡수됨).
enum SeatStatus {
  AVAILABLE
  OCCUPIED
}

enum CheckoutReason {
  MANUAL
  AWAY_EXPIRED
  REPORT_EXPIRED
}

enum AwayEndReason {
  RETURNED
  AUTO_EXPIRED
  /// 외출 중 본인이 그대로 체크아웃해버린 예외 케이스 (DB.md 2.6절)
  SESSION_CHECKOUT
}

enum ReportStatus {
  ACTIVE
  CANCELLED_RETURN
  AUTO_EXPIRED
  /// 신고당한 사람이 "자리 복귀를 인증하세요" 팝업에서 자리 복귀 대신 체크아웃을 선택한 경우
  CHECKED_OUT
}

/// F16 알림 유형 (DB.md 2.8절 표 그대로)
enum NotificationType {
  CHECKIN_COMPLETE
  CHECKOUT_COMPLETE
  AWAY_STARTED
  AWAY_WARNING
  AWAY_AUTO_EXPIRED
  REPORT_RECEIVED
  REPORT_WARNING
  REPORT_AUTO_EXPIRED_OCCUPANT
  REPORT_AUTO_EXPIRED_REPORTER
  REPORT_CANCELLED
  /// 신고당한 사람이 신고 처리 팝업에서 체크아웃을 선택했을 때 신고자에게 보내는 알림
  REPORT_CHECKED_OUT
  /// 관심 좌석이 비었을 때(SeatWatchRequest) — 팀원 기능, 이 파일에는 역반영만 함
  SEAT_WATCH_AVAILABLE
  /// "체크아웃 시 알림"을 신청한 좌석이 실제로 체크아웃됐을 때(F22)
  CHECKOUT_ALARM_TRIGGERED
}

/// 마이페이지 배지/칭호 4종 — 기준은 lib/badges.ts 참고
enum BadgeCode {
  /// 도서관 터줏대감 — 한 달 동안 자동반납/경고 없이 최소 50시간 집중
  LIBRARY_REGULAR
  /// 칼복귀 마스터 — 자리비움 제한시간보다 최소 5분 이상 남기고 복귀(누적 횟수 기준)
  PRECISE_RETURN_MASTER
  /// 정의의 보안관 — 실제로 자리를 비운 좌석 신고가 적중(누적 횟수 기준)
  JUSTICE_SHERIFF
  /// 바람과 함께 사라지다 — 자리비움 신청 없이 신고당해 자동반납된 횟수 3회(불명예 칭호)
  GONE_WITH_THE_WIND
  /// 금주의 인증샷 — 본인 게시글이 좋아요 100개 이상 받은 적 있음(누적, ALL_TIME으로 단순화 — lib/badges.ts 주석 참고)
  WEEKLY_CERT_STAR
  /// 커뮤니티 수호자 — 댓글 활동이 활발함(누적 댓글 수 기준, lib/badges.ts 주석 참고)
  COMMUNITY_GUARDIAN
}
